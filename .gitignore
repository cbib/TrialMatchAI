elasticsearch/.env
elasticsearch/certs/
elasticsearch/config/
elasticsearch/tmp-config/
elasticsearch/sif/
elasticsearch/data1/
elasticsearch/data/
elasticsearch/logs/
elasticsearch/sif/*.sif
*.keystore

